  { key:"noteDemoQuality",    label:"Demo Quality",           placeholder:"Was the product polished or early-stage? Live demo or slides?" },
  { key:"noteRedFlags",       label:"Red Flags",              placeholder:"Anything concerning said at the booth or in the demo?" },
  { key:"noteFollowUp",       label:"Follow-Up Action",       placeholder:"Who do you need to contact? What do you need from them?" },
];

