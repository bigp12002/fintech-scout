  noteDemoQuality:"",noteRedFlags:"",noteFollowUp:"",
  notes:"",noteHistory:[],
  folderId:null,
  // Per-vendor scoring snapshot
  vendorWeights:null,vendorWeightLabels:null,vendorMustHaves:null,
